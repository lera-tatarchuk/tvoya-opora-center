---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const MONTHS = ['січня', 'лютого', 'березня', 'квітня', 'травня', 'червня', 'липня', 'серпня', 'вересня', 'жовтня', 'листопада', 'грудня'];
const colorVar = { violet: 'var(--violet)', coral: 'var(--coral)', gold: 'var(--gold)' };
const events = (await getCollection('events')).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---
<Base title="Події та розклад — Сімейний центр «Твоя опора»" description="Анонси заходів і груп центру, розклад на тиждень та завершені освітні ініціативи.">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">Події та заходи</span>
      <h1>Анонси й розклад центру</h1>
      <p>Заходи для дітей, підлітків і дорослих. Реєструйтеся заздалегідь — кількість місць обмежена.</p>
    </div>
  </section>

  <section class="events" style="padding-bottom:0">
    <div class="wrap">
      <div class="fest reveal">
        <span class="blob" style="width:260px;height:260px;background:var(--yellow);top:-80px;right:-40px"></span>
        <span class="eyebrow">Найбільший в Україні сімейний благодійний фестиваль</span>
        <h2>CHARITY FAMILY DAY 2026</h2>
        <div class="fest-facts">
          <div><span class="ico">📅</span> 5 і 6 вересня 2026 року</div>
          <div><span class="ico">📍</span> Бучанський міський парк</div>
          <div><span class="ico">🎟️</span> Вхід вільний</div>
        </div>
        <a class="btn btn-yellow" href="https://www.charityfamilyday.org/" target="_blank" rel="noopener">Детальніше про фестиваль ↗</a>
      </div>
    </div>
  </section>

  <section class="events" id="events">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Анонси подій</span><h2>Що відбуватиметься найближчим часом</h2></div>
      <div class="ev-grid">
        {events.map((e) => (
          <article class="ev-card reveal">
            <div class="ev-top" style={`background:${colorVar[e.data.color]}`}>
              <span class="date">{e.data.date.getUTCDate()}<small>{MONTHS[e.data.date.getUTCMonth()]}</small></span>
              <span class="pill">{e.data.audience}</span>
            </div>
            <div class="ev-body">
              <h3>{e.data.title}</h3>
              <p>{e.data.description}</p>
              <a class="btn btn-primary" href={e.data.formUrl || '/help#booking'} target={e.data.formUrl ? '_blank' : null} rel={e.data.formUrl ? 'noopener' : null}>Зареєструватися</a>
            </div>
          </article>
        ))}
      </div>
      <p class="sch-note reveal">📌 Актуальні анонси — у <a href="https://t.me/mental_center_tvoya_opora" target="_blank" rel="noopener" style="color:var(--coral);font-weight:700">Telegram-каналі</a>.</p>
    </div>
  </section>

  <section class="schedule" id="schedule">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Розклад заходів і груп</span><h2>Що відбувається в центрі цього тижня</h2></div>
      <div class="sch-table reveal">
        <div class="sch-row"><span class="day">Понеділок</span><span class="ev"><b>Група підтримки для батьків</b><small>10:00 — 11:30</small></span><span class="who">Дорослі</span></div>
        <div class="sch-row"><span class="day">Вівторок</span><span class="ev"><b>Сенсорні заняття для малечі</b><small>11:00 — 12:00</small></span><span class="who">Діти 3–6</span></div>
        <div class="sch-row"><span class="day">Середа</span><span class="ev"><b>Тренінг: фінансова грамотність</b><small>15:00 — 17:00</small></span><span class="who">Родини</span></div>
        <div class="sch-row"><span class="day">Четвер</span><span class="ev"><b>Арттерапевтична група для підлітків</b><small>16:00 — 17:30</small></span><span class="who">Підлітки</span></div>
        <div class="sch-row"><span class="day">П'ятниця</span><span class="ev"><b>Психоедукація: як говорити з дитиною про війну</b><small>11:00 — 12:30</small></span><span class="who">Дорослі</span></div>
        <div class="sch-row"><span class="day">Субота</span><span class="ev"><b>Сімейний день: ігри та майстерні</b><small>11:00 — 14:00</small></span><span class="who">Усі</span></div>
      </div>
      <p class="sch-note reveal">📌 Розклад орієнтовний і оновлюється щотижня. Запис — за телефоном, актуальні анонси — у <a href="https://t.me/mental_center_tvoya_opora" target="_blank" rel="noopener" style="color:var(--coral);font-weight:700">Telegram-каналі</a>.</p>
    </div>
  </section>

  <section class="vsection" id="course">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Освітні ініціативи</span><h2>Що вже відбулось у центрі</h2></div>
      <div class="course-card reveal">
        <img class="course-img" src="/assets/guest-buhovska.jpg" alt="Курс з журналістики для ВПО з Юлією Буговською" loading="lazy">
        <div class="course-body">
          <span class="done-badge">Курс завершено</span>
          <h3>Безкоштовний курс з журналістики для ВПО і СЖО</h3>
          <p>Офлайн-курс у центрі для дорослих зі статусом ВПО та осіб у складних життєвих обставинах (СЖО): основи журналістики, робота в різних форматах і перші кроки в медіа. Вела курс Юлія Буговська — журналістка, тележурналістка й редакторка, за підтримки GlobalGiving.</p>
          <p class="course-note">Стежте за анонсами нових наборів у <a href="https://t.me/mental_center_tvoya_opora" target="_blank" rel="noopener">Telegram-каналі</a>.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
