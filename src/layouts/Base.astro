---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Сімейний центр ментального благополуччя «Твоя опора» — Ворзель',
  description = 'Безкоштовна комплексна психосоціальна підтримка для дітей та їхніх сімей, що відповідають критеріям центру. Платних послуг не надаємо. смт Ворзель, вул. Ворзельська, 24.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FFCC00" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="uk_UA" />
  <meta property="og:site_name" content="Сімейний центр ментального благополуччя «Твоя опора»" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/assets/swallow.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <Header />
  <slot />
  <Footer />

  <a class="donate-fab" href="https://send.monobank.ua/jar/8kbJBXHkzj" target="_blank" rel="noopener" aria-label="Підтримати центр">
    <span class="h">❤</span> Підтримати
  </a>

  <script>
    const header = document.getElementById('top');
    addEventListener('scroll', () => header && header.classList.toggle('scrolled', scrollY > 10));

    const burger = document.getElementById('burger');
    const links = document.getElementById('navLinks');
    if (burger && links) {
      burger.addEventListener('click', () => links.classList.toggle('open'));
      links.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => links.classList.remove('open')));
    }

    const io = new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

    const fmt = (n) => n.toLocaleString('uk-UA');
    const countIO = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target, target = +el.dataset.count, suf = el.dataset.suffix || '';
        let cur = 0; const inc = target / 45;
        const tick = () => { cur += inc; if (cur >= target) { el.textContent = fmt(target) + suf; } else { el.textContent = fmt(Math.floor(cur)) + suf; requestAnimationFrame(tick); } };
        tick(); countIO.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach((el) => countIO.observe(el));

    const RECS = [
      ['Психолог', 'Рекомендуємо почати з консультації дитячого психолога.'],
      ['Психолог', 'Рекомендуємо консультацію психолога для дорослих — підтримка батьків і опікунів важлива не менше.'],
      ['Нейропсихолог', 'Рекомендуємо нейропсихолога — оцінить увагу, памʼять і підкаже стратегію.'],
      ['Логопед', 'Рекомендуємо логопеда для діагностики мовленнєвого розвитку.'],
      ['Дефектолог', 'Рекомендуємо дефектолога — складе індивідуальну програму супроводу.'],
      ['Юрист', 'Рекомендуємо юриста центру — допоможе зі статусами, виплатами й документами.'],
      ['Фахівець з працевлаштування', 'Рекомендуємо фахівця з працевлаштування.'],
      ['Кейс-менеджер', 'Почніть із кейс-менеджера — він зорієнтує й підбере потрібних фахівців для всієї родини.'],
    ];
    const chips = document.getElementById('chips');
    if (chips) {
      const res = document.getElementById('navResult');
      const rb = document.getElementById('recBadge');
      const rt = document.getElementById('recText');
      chips.addEventListener('click', (e) => {
        const b = e.target.closest('.chip'); if (!b) return;
        chips.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
        b.classList.add('active');
        const r = RECS[+b.dataset.rec]; rb.textContent = r[0]; rt.textContent = r[1];
        res.classList.add('show');
      });
    }

    const bf = document.getElementById('bookForm');
    if (bf) bf.addEventListener('submit', (e) => {
      e.preventDefault(); const f = e.target;
      const body = `Імʼя: ${f.name.value}%0D%0AТелефон: ${f.phone.value}%0D%0AКому потрібна допомога: ${f.who.value}%0D%0AФахівець: ${f.spec.value}%0D%0AЗапит: ${f.msg.value}`;
      window.location.href = `mailto:info@tvoya-opora.org.ua?subject=${encodeURIComponent('Заявка з сайту центру')}&body=${body}`;
    });

    const pf = document.getElementById('partnerForm');
    if (pf) pf.addEventListener('submit', (e) => {
      e.preventDefault(); const f = e.target;
      const body = `ПІБ: ${f.name.value}%0D%0AКомпанія: ${f.company.value}%0D%0AІмейл: ${f.email.value}%0D%0AТелефон: ${f.phone.value}%0D%0AКоментарі: ${f.msg.value}`;
      window.location.href = `mailto:tatarchuklera@tvoya-opora.org.ua?subject=${encodeURIComponent('Заявка на партнерство — Давай на ти')}&body=${body}`;
    });
  </script>
</body>
</html>
