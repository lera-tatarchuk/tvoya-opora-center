---
import Base from '../layouts/Base.astro';
---
<Base>
  <section class="hero">
    <span class="blob" style="width:260px;height:260px;background:var(--yellow-light);top:-60px;left:-40px"></span>
    <span class="blob" style="width:180px;height:180px;background:var(--violet-light);bottom:-40px;right:8%"></span>
    <div class="wrap hero-grid">
      <div class="reveal">
        <span class="eyebrow">смт Ворзель · вул. Ворзельська, 24</span>
        <h1>Простір, де <span class="hl">сім'я</span> віднаходить опору</h1>
        <p class="lead">Сімейний центр ментального благополуччя «Твоя опора» — комплексна психосоціальна підтримка для дітей та їхніх сімей. Бо стійкий результат можливий лише тоді, коли поруч ціла родина.</p>
        <div class="badge-free">
          <span class="dot"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12l4 4 10-10" stroke="#2b2b3a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          Усе <span style="color:var(--coral)">безкоштовно</span> — для дітей та родин, які потребують підтримки
        </div>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/help#booking">Записатися на консультацію</a>
          <a class="btn btn-ghost" href="/help">Хто може звернутися</a>
        </div>
      </div>
      <div class="hero-art reveal">
        <div class="hero-card">
          <span class="float f1"><span class="num" style="color:var(--coral)">3500+</span> родин<br>отримали допомогу</span>
          <span class="float f2"><span class="num" style="color:var(--violet)">13 000+</span> наданих<br>послуг</span>
          <img class="big-swallow" src="/assets/swallow.png" alt="Ластівка — символ центру «Твоя опора»">
        </div>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Центр у цифрах</span>
        <h2>Працюємо з 2024 року — і вже стали опорою для тисяч</h2>
      </div>
      <div class="stats-grid">
        <div class="stat reveal"><div class="n" data-count="13000" data-suffix="+">0</div><div class="l">наданих послуг</div></div>
        <div class="stat reveal"><div class="n" data-count="3500" data-suffix="+">0</div><div class="l">бенефіціарів</div></div>
        <div class="stat reveal"><div class="n" data-count="46" data-suffix="%">0</div><div class="l">бенефіціарів — ВПО</div></div>
        <div class="stat reveal"><div class="n" data-count="470" data-suffix=" м²">0</div><div class="l">три поверхи + автономне укриття ДСНС</div></div>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Наш підхід</span><h2>Одиниця нашої допомоги — сім'я, а не окрема дитина</h2>
        <p class="lead" style="margin-top:14px">Стійкий результат можливий лише за умови одночасної роботи з дитиною та її середовищем догляду. Тому ми підтримуємо всю родину.</p></div>
      <div class="hero-actions reveal" style="margin-top:26px">
        <a class="btn btn-ghost" href="/about">Докладніше про центр</a>
      </div>
    </div>
  </section>

  <section class="vsection">
    <div class="wrap">
      <div class="sec-head reveal" style="text-align:center;margin:0 auto"><span class="eyebrow">Відео</span><h2>Подивіться, як живе наш центр</h2></div>
      <div class="video-wrap reveal" style="margin:32px auto 0;max-width:900px">
        <iframe src="https://www.youtube-nocookie.com/embed/dI_aw3QjhPU" title="Сімейний центр ментального благополуччя «Твоя опора»" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen loading="lazy"></iframe>
      </div>
    </div>
  </section>

  <section class="services">
    <div class="wrap">
      <div class="sec-head reveal"><span class="eyebrow">Куди далі</span><h2>З чого почати</h2></div>
      <div class="cards">
        <a class="card reveal" href="/help"><div class="ico c-c">🤝</div><h3>Як отримати допомогу</h3><p>Кроки, хто може звернутися, потрібні документи та форма запису.</p></a>
        <a class="card reveal" href="/services"><div class="ico c-v">🧠</div><h3>Послуги та фахівці</h3><p>Психологи, логопеди, нейропсихологи, юристи — і навігатор, який підкаже фахівця.</p></a>
        <a class="card reveal" href="/events"><div class="ico c-y">⭐</div><h3>Події та «Давай на ти»</h3><p>Анонси заходів, розклад груп і спецпроєкт для підлітків.</p></a>
      </div>
    </div>
  </section>
</Base>
